FROM eclipse-temurin:21-jdk-alpine AS build
WORKDIR /app

COPY gradlew .
COPY gradle gradle
COPY gateway/build.gradle.kts build.gradle.kts

# [중요] 게이트웨이와 common만 인식하도록 설정 (elasticsearch 등 다른 모듈 제외)
RUN echo 'rootProject.name = "backend"' > settings.gradle.kts && \
    echo 'include("common")' >> settings.gradle.kts && \
    echo 'include("gateway")' >> settings.gradle.kts

# 필요한 모듈만 복사 (에러 날 확률 차단)
COPY common common
COPY gateway/src src

RUN chmod +x gradlew && ./gradlew bootJar --no-daemon -x test

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /app/build/libs/*.jar app.jar

EXPOSE 8080
ENTRYPOINT ["java", "-Dspring.profiles.active=prod", "-jar", "app.jar"]